# =============================================================================
# MedSafe — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored. NEVER commit real secrets.
# =============================================================================


# =============================================================================
# SUPABASE
# Find these at: Supabase Dashboard → Settings → API
# =============================================================================

# Public project URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to expose to the browser
# Row Level Security (RLS) policies enforce access control, not this key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Service role key — SERVER-SIDE ONLY. Has full DB access, bypasses RLS.
# Used only in Next.js API routes (never in client components or hooks).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here


# =============================================================================
# DATABASE — PRISMA
# Find these at: Supabase Dashboard → Settings → Database → Connection string
# =============================================================================

# Pooled connection via Supabase Supavisor (PgBouncer transaction mode)
# Used for ALL runtime queries (Prisma Client at app runtime)
# Required params: ?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct (non-pooled) connection
# Used ONLY for `prisma migrate dev` and `prisma migrate deploy` — never at runtime
# Find under: Connection string → Direct connection tab
DIRECT_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres


# =============================================================================
# FASTAPI BACKEND (OCR + Drug Resolution)
# Phase 5+ only. Backend runs on Render free tier.
# Local dev: http://localhost:8000
# Production: https://medsafe-api-docker.onrender.com
# =============================================================================

FASTAPI_BACKEND_URL=http://localhost:8000


# =============================================================================
# NOTIFICATIONS — RESEND
# Sign up at: https://resend.com (free tier: 3,000 emails/month, no card required)
# Create an API key at: Resend Dashboard → API Keys
# =============================================================================

RESEND_API_KEY=re_your_resend_api_key_here

# Sender address for expiry alert emails
# Must be a verified domain on Resend.
# For local dev, use: onboarding@resend.dev (Resend's test address, no domain needed)
RESEND_FROM_EMAIL=onboarding@resend.dev


# =============================================================================
# CRON SECURITY
# The /api/cron/check-expiry route is triggered by cron-job.org daily.
# This secret prevents unauthorized calls to that endpoint.
# Set the same value in cron-job.org as a custom request header: X-Cron-Secret
# Generate a value: openssl rand -hex 32
# =============================================================================

CRON_SECRET=replace-with-a-random-32-char-string


# =============================================================================
# APP CONFIG
# =============================================================================

# Canonical base URL — used when constructing absolute URLs (e.g. email links)
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000


# =============================================================================
# OPTIONAL — ERROR MONITORING (Phase 6+)
# Leave blank to disable. No errors will be captured if unset.
# Sign up at: https://sentry.io (free tier: 5,000 errors/month)
# =============================================================================

SENTRY_DSN=
